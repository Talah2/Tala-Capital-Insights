import yfinance as yf  # استيراد مكتبة yfinance لجلب البيانات المالية
import pandas as pd  # استيراد مكتبة pandas لمعالجة البيانات
import matplotlib.pyplot as plt  # استيراد مكتبة matplotlib لرسم البيانات
import numpy as np  # استيراد مكتبة numpy لإجراء العمليات الحسابية
import scipy.optimize as sco  # استيراد مكتبة scipy لإيجاد المحفظة المثلى

# تحديد الرموز للأصول المالية المختارة
assets = ['TSLA', 'QUAL', 'ICLN', 'VNQ', 'O', 'RWR','IGF', 'IYR', 'SPY', 'GLD']  # أسهم آبل، جوجل، مايكروسوفت، وتسلا

# تحميل البيانات من ياهو فايننس لمدة سنتين
start_date = '2019-01-01'  # تاريخ البدء
end_date = '2024-01-01'  # تاريخ الانتهاء

data = yf.download(assets, start=start_date, end=end_date)['Close']  # جلب أسعار الإغلاق فقط

# تنظيف البيانات
data.dropna(inplace=True)  # حذف القيم المفقودة إن وجدت

# حساب العوائد اليومية باستخدام اللوغاريتم الطبيعي
returns = np.log(data / data.shift(1)).dropna()  # حساب العوائد اليومية اللوغاريتمية

# حساب العائد السنوي والانحراف المعياري لكل أصل مالي
mean_returns = returns.mean() * 252
std_devs = returns.std() * np.sqrt(252)

# توليد المحافظ العشوائية واختيار الأفضل بناءً على نسبة شارب
num_assets = len(assets)
num_portfolios = 10000
results = np.zeros((3, num_portfolios))
weights_record = []

for i in range(num_portfolios):
   weights = np.random.dirichlet(np.ones(num_assets), size=1).flatten()
   weights_record.append(weights)
   port_return = np.sum(weights * mean_returns)
   port_volatility = np.sqrt(np.dot(weights.T, np.dot(returns.cov() * 252, weights)))
   results[0, i] = port_return
   results[1, i] = port_volatility
   results[2, i] = port_return / port_volatility

# اختيار المحافظ التي تقع على الجبهة الفعالة
sorted_indices = np.argsort(results[1])
efficient_frontier_x = results[1, sorted_indices]
efficient_frontier_y = results[0, sorted_indices]

# إيجاد المحفظة المثلى بناءً على أعلى نسبة شارب
max_sharpe_idx = np.argmax(results[2])
optimal_weights = weights_record[max_sharpe_idx]
optimal_return = results[0, max_sharpe_idx]
optimal_volatility = results[1, max_sharpe_idx]

print("\nEfficient Frontier and Capital Allocation Line (CAL):")
print(f"Optimal Portfolio Expected Return: {optimal_return:.4f}")
print(f"Optimal Portfolio Expected Volatility: {optimal_volatility:.4f}")
print(f"Optimal Portfolio Weights: {optimal_weights}")

# رسم الجبهة الفعالة بالنقاط الملونة
plt.figure(figsize=(12, 6))
plt.scatter(results[1, :], results[0, :], c=results[2, :], cmap='viridis', marker='o', alpha=0.7, label='Portfolios')
plt.colorbar(label='Sharpe Ratio')
plt.scatter(optimal_volatility, optimal_return, color='red', marker='*', s=200, label='Optimal Portfolio')

# رسم خط تخصيص رأس المال (CAL)
risk_free_rate = 0.02  # افتراض معدل خالي من المخاطر
x = np.linspace(0, max(results[1, :]) * 1.5, 100)
y = risk_free_rate + ((optimal_return - risk_free_rate) / optimal_volatility) * x
plt.plot(x, y, color='blue', linestyle='dashed', linewidth=2, label='Capital Allocation Line (CAL)')

plt.xlabel('Standard Deviation')
plt.ylabel('Expected Return')
plt.title('Efficient Frontier')
plt.legend()
plt.grid(True, linestyle='--', linewidth=0.5)
plt.show()

# حساب العائد المتوقع لكل أصل بناءً على الأوزان المثلى
individual_returns = optimal_weights * mean_returns

# وضع النتائج في DataFrame لسهولة العرض
portfolio_breakdown = pd.DataFrame({
    'Asset': assets,
    'Weight': optimal_weights,
    'Expected Return': mean_returns,
    'Contribution to Portfolio Return': individual_returns
})

# ترتيب حسب أكبر مساهمة في العائد
portfolio_breakdown.sort_values(by='Contribution to Portfolio Return', ascending=False, inplace=True)

# عرض النتائج
print("\nIndividual Asset Contributions to Portfolio Return:")
print(portfolio_breakdown)

mean_returns = returns.mean() * 252
std_devs = returns.std() * np.sqrt(252)
# عرض الانحراف المعياري لكل أصل في جدول
std_deviation_df = pd.DataFrame({
    'Asset': assets,
    'Standard Deviation': std_devs
}).sort_values(by='Standard Deviation', ascending=False)

print("\nStandard Deviation (Risk) per Asset:")
print(std_deviation_df)

optimal_return = results[0, max_sharpe_idx]
optimal_volatility = results[1, max_sharpe_idx]
portfolio_std = optimal_volatility  # Assign optimal_volatility to portfolio_std
# استخدام SPY كمؤشر للسوق
market_returns = returns['SPY']

# حساب بيتا لكل أصل
betas = []
for asset in assets:
    cov_matrix = np.cov(returns[asset], market_returns)
    beta = cov_matrix[0, 1] / cov_matrix[1, 1]
    betas.append(beta)

# حساب بيتا المحفظة كمتوسط مرجح
portfolio_beta = np.dot(optimal_weights, betas)
print("\nPortfolio Metrics (CAPM):")
print(f"Expected Portfolio Return: {optimal_return:.4f}")  # Use optimal_return instead of portfolio_return
print(f"Portfolio Standard Deviation: {portfolio_std:.4f}")
print(f"Portfolio Beta (vs SPY): {portfolio_beta:.4f}")

# استخدام نموذج CAPM لحساب العائد المتوقع للمحفظة
# Rf: معدل خالي من المخاطر (2%)
# Rm: العائد المتوقع للسوق (من SPY)

market_return = mean_returns['SPY']  # العائد المتوقع للسوق
expected_return_capm = risk_free_rate + portfolio_beta * (market_return - risk_free_rate)

print("\nCAPM Expected Return for the Portfolio:")
print(f"CAPM Expected Return: {expected_return_capm:.4f}")

# حساب العائد اليومي للمحفظة بناءً على الأوزان المثلى
portfolio_daily_returns = returns.dot(optimal_weights)
# استخراج عوائد السوق اليومية (SPY)
market_daily_returns = returns['SPY']

# حساب معامل الارتباط
correlation = portfolio_daily_returns.corr(market_daily_returns)

print("\nCorrelation between Portfolio and Market (SPY):")
print(f"Correlation: {correlation:.4f}")

# رسم بياني يوضح العائد السنوي لكل أصل
plt.figure(figsize=(12, 6))
plt.bar(mean_returns.index, mean_returns.values, color='skyblue', edgecolor='black')
plt.xlabel('Assets')
plt.ylabel('Expected Annual Return')
plt.title('Expected Annual Return per Asset')
plt.xticks(rotation=45)
plt.grid(axis='y', linestyle='--', linewidth=0.5)
plt.tight_layout()
plt.show()

# حساب العائد اليومي للمحفظة
portfolio_daily_returns = returns.dot(optimal_weights)

# عوائد السوق اليومية (SPY)
market_daily_returns = returns['SPY']

# حساب بيتا (slope) باستخدام الانحدار الخطي
slope, intercept = np.polyfit(market_daily_returns, portfolio_daily_returns, 1)

# حساب معامل الارتباط
correlation = portfolio_daily_returns.corr(market_daily_returns)

# حساب العائد السنوي للمحفظة (تم حسابه سابقاً)
# موجود في المتغير: optimal_return

# رسم Scatter Plot
plt.figure(figsize=(10, 6))
plt.scatter(market_daily_returns, portfolio_daily_returns, alpha=0.5, color='teal', edgecolor='k', label='Daily Returns')

# رسم خط الاتجاه
plt.plot(market_daily_returns, slope * market_daily_returns + intercept, color='red', linewidth=2,
         label=f'Line of Best Fit\nBeta ≈ {slope:.2f}\nCorrelation ≈ {correlation:.2f}')

# رسم نقطة تمثل المحفظة ككل (عائد سنوي، انحراف معياري)
plt.scatter(returns['SPY'].mean() * 252, optimal_return, color='gold', s=150, marker='*', label='Portfolio (Annual Return)')

# تعليق على النقطة الذهبية
plt.text(returns['SPY'].mean() * 252, optimal_return,
         f'Portfolio Return:\n{optimal_return:.2%}', fontsize=10, ha='left', va='bottom')

# إعدادات الشكل
plt.xlabel('Market (SPY) Daily Returns')
plt.ylabel('Portfolio Daily Returns')
plt.title('Portfolio vs Market (SPY) Returns')
plt.legend()
plt.grid(True, linestyle='--', linewidth=0.5)
plt.tight_layout()
plt.show()

import matplotlib.pyplot as plt

# رسم بياني يوضح الانحراف المعياري السنوي لكل أصل
plt.figure(figsize=(12, 6))
plt.bar(std_devs.index, std_devs.values, color='salmon', edgecolor='black')
plt.xlabel('Assets')
plt.ylabel('Annualized Standard Deviation (Risk)')
plt.title('Annualized Risk (Standard Deviation) per Asset')
plt.xticks(rotation=45)
